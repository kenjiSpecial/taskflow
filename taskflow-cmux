#!/usr/bin/env bash
set -euo pipefail

# ─── Constants ────────────────────────────────────────────────────────────────

readonly CONFIG_DIR="${HOME}/.taskflow-cmux"
readonly MAPPINGS_FILE="${CONFIG_DIR}/mappings.json"
readonly CONFIG_FILE="${CONFIG_DIR}/config.json"
readonly DEFAULT_API_URL="https://taskflow.kenji-draemon.workers.dev"
readonly MIN_PREFIX_LEN=4

# ─── Colors ───────────────────────────────────────────────────────────────────

if [[ -t 1 ]]; then
  readonly RED='\033[0;31m'
  readonly GREEN='\033[0;32m'
  readonly YELLOW='\033[0;33m'
  readonly BLUE='\033[0;34m'
  readonly BOLD='\033[1m'
  readonly DIM='\033[2m'
  readonly RESET='\033[0m'
else
  readonly RED='' GREEN='' YELLOW='' BLUE='' BOLD='' DIM='' RESET=''
fi

# ─── Logging ──────────────────────────────────────────────────────────────────

die()         { echo -e "${RED}error:${RESET} $*" >&2; exit 1; }
log_info()    { echo -e "${BLUE}info:${RESET} $*"; }
log_success() { echo -e "${GREEN}ok:${RESET} $*"; }
log_warn()    { echo -e "${YELLOW}warn:${RESET} $*" >&2; }
log_debug()   { [[ "${TASKFLOW_CMUX_DEBUG:-}" == "1" ]] && echo -e "${DIM}debug: $*${RESET}" >&2 || true; }

# ─── Usage ────────────────────────────────────────────────────────────────────

usage() {
  cat <<'EOF'
Usage: taskflow-cmux <command> [args]

Commands:
  start <session-id>   セッションのworkspaceを作成
  stop <session-id>    workspaceを閉じてセッションを完了
  update <session-id>  サイドバー情報を更新
  sync                 全アクティブセッションの状態を同期
  status               マッピング状態を表示

Environment:
  TASKFLOW_API_URL     API URL (default: https://taskflow.kenji-draemon.workers.dev)
  TASKFLOW_API_TOKEN   API Token (required)
  TASKFLOW_CMUX_DEBUG  デバッグモード (1 で有効)

Config: ~/.taskflow-cmux/config.json
EOF
}

# ─── Dependencies ─────────────────────────────────────────────────────────────

check_deps() {
  local missing=()
  command -v cmux  >/dev/null 2>&1 || missing+=("cmux")
  command -v jq    >/dev/null 2>&1 || missing+=("jq")
  command -v curl  >/dev/null 2>&1 || missing+=("curl")
  if [[ ${#missing[@]} -gt 0 ]]; then
    die "必要なコマンドが見つかりません: ${missing[*]}"
  fi
}

# ─── Config ───────────────────────────────────────────────────────────────────

init_config_dir() {
  mkdir -p "$CONFIG_DIR"
  if [[ ! -f "$MAPPINGS_FILE" ]]; then
    echo '{"mappings":[]}' > "$MAPPINGS_FILE"
    log_debug "mappings.json を作成しました"
  fi
  # config.json のパーミッション警告
  if [[ -f "$CONFIG_FILE" ]]; then
    local perms
    perms=$(stat -f '%Lp' "$CONFIG_FILE" 2>/dev/null || stat -c '%a' "$CONFIG_FILE" 2>/dev/null || echo "")
    if [[ -n "$perms" && "$perms" != "600" ]]; then
      log_warn "config.json のパーミッションが ${perms} です。chmod 600 を推奨します"
    fi
  fi
}

load_config() {
  init_config_dir

  # API URL: ENV → config.json → default
  if [[ -n "${TASKFLOW_API_URL:-}" ]]; then
    API_URL="$TASKFLOW_API_URL"
  elif [[ -f "$CONFIG_FILE" ]] && jq -e '.api_url' "$CONFIG_FILE" >/dev/null 2>&1; then
    API_URL=$(jq -r '.api_url' "$CONFIG_FILE")
  else
    API_URL="$DEFAULT_API_URL"
  fi

  # API Token: ENV → config.json
  if [[ -n "${TASKFLOW_API_TOKEN:-}" ]]; then
    API_TOKEN="$TASKFLOW_API_TOKEN"
  elif [[ -f "$CONFIG_FILE" ]] && jq -e '.api_token' "$CONFIG_FILE" >/dev/null 2>&1; then
    API_TOKEN=$(jq -r '.api_token' "$CONFIG_FILE")
  else
    die "API トークンが設定されていません。TASKFLOW_API_TOKEN を設定するか、${CONFIG_FILE} に api_token を追加してください"
  fi

  # Project dirs: config.json の project_dirs を読み込み
  PROJECT_DIRS_JSON="{}"
  if [[ -f "$CONFIG_FILE" ]] && jq -e '.project_dirs' "$CONFIG_FILE" >/dev/null 2>&1; then
    PROJECT_DIRS_JSON=$(jq '.project_dirs' "$CONFIG_FILE")
  fi

  log_debug "API_URL=${API_URL}"
}

# ─── Project Directory Resolution ─────────────────────────────────────────────

resolve_project_dir() {
  local project_name="$1"
  [[ -z "$project_name" ]] && return 1

  # 1. ローカルオーバーライド (config.json の project_dirs)
  local dir
  dir=$(echo "$PROJECT_DIRS_JSON" | jq -r --arg p "$project_name" '.[$p] // empty')
  if [[ -n "$dir" ]]; then
    echo "${dir/#\~/$HOME}"
    return 0
  fi

  # 2. API の project directory_path
  local project_id="$2"
  if [[ -n "$project_id" ]]; then
    local proj_data
    proj_data=$(api_get "/api/projects/${project_id}" 2>/dev/null) || return 1
    dir=$(echo "$proj_data" | jq -r '.project.directory_path // empty')
    if [[ -n "$dir" ]]; then
      echo "${dir/#\~/$HOME}"
      return 0
    fi
  fi

  return 1
}

# ─── API Helpers ──────────────────────────────────────────────────────────────

api_get() {
  local path="$1"
  local url="${API_URL}${path}"
  log_debug "GET ${url}"

  local http_code body
  body=$(curl -sS -w '\n%{http_code}' \
    -H "Authorization: Bearer ${API_TOKEN}" \
    -H "Content-Type: application/json" \
    "$url" 2>&1) || die "APIに接続できません: ${url}"

  http_code=$(echo "$body" | tail -1)
  body=$(echo "$body" | sed '$d')

  log_debug "HTTP ${http_code}"
  log_debug "Response: ${body}"

  case "$http_code" in
    2*) echo "$body" ;;
    401) die "API認証に失敗しました。TASKFLOW_API_TOKEN を確認してください" ;;
    404) die "リソースが見つかりません: ${path}" ;;
    5*) die "APIサーバーエラー: HTTP ${http_code}" ;;
    *) die "APIエラー: HTTP ${http_code}" ;;
  esac
}

api_patch() {
  local path="$1"
  local data="$2"
  local url="${API_URL}${path}"
  log_debug "PATCH ${url} ${data}"

  local http_code body
  body=$(curl -sS -w '\n%{http_code}' \
    -X PATCH \
    -H "Authorization: Bearer ${API_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$data" \
    "$url" 2>&1) || die "APIに接続できません: ${url}"

  http_code=$(echo "$body" | tail -1)
  body=$(echo "$body" | sed '$d')

  log_debug "HTTP ${http_code}"

  case "$http_code" in
    2*) echo "$body" ;;
    401) die "API認証に失敗しました。TASKFLOW_API_TOKEN を確認してください" ;;
    404) die "リソースが見つかりません: ${path}" ;;
    5*) die "APIサーバーエラー: HTTP ${http_code}" ;;
    *) die "APIエラー: HTTP ${http_code} - ${body}" ;;
  esac
}

# ─── Mappings ─────────────────────────────────────────────────────────────────

read_mappings() {
  if [[ ! -f "$MAPPINGS_FILE" ]]; then
    echo '{"mappings":[]}'
    return
  fi
  jq '.' "$MAPPINGS_FILE" 2>/dev/null || die "mappings.json が不正です。削除して再作成してください: rm ${MAPPINGS_FILE}"
}

write_mappings() {
  local data="$1"
  echo "$data" | jq '.' > "$MAPPINGS_FILE" 2>/dev/null || die "mappings.json の書き込みに失敗しました"
}

add_mapping() {
  local session_id="$1" workspace_id="$2"
  local mappings
  mappings=$(read_mappings)
  mappings=$(echo "$mappings" | jq --arg sid "$session_id" --arg wid "$workspace_id" \
    '.mappings += [{"session_id": $sid, "workspace_id": $wid, "created_at": (now | todate)}]')
  write_mappings "$mappings"
}

remove_mapping() {
  local session_id="$1"
  local mappings
  mappings=$(read_mappings)
  mappings=$(echo "$mappings" | jq --arg sid "$session_id" '.mappings |= map(select(.session_id != $sid))')
  write_mappings "$mappings"
}

find_workspace_id() {
  local session_id="$1"
  read_mappings | jq -r --arg sid "$session_id" '.mappings[] | select(.session_id == $sid) | .workspace_id // empty'
}

has_mapping() {
  local session_id="$1"
  local wid
  wid=$(find_workspace_id "$session_id")
  [[ -n "$wid" ]]
}

# ─── Prefix Match ────────────────────────────────────────────────────────────

resolve_session_id_from_mappings() {
  local prefix="$1"
  local mappings
  mappings=$(read_mappings)

  # 完全一致を先にチェック
  local exact
  exact=$(echo "$mappings" | jq -r --arg p "$prefix" '.mappings[] | select(.session_id == $p) | .session_id')
  if [[ -n "$exact" ]]; then
    echo "$exact"
    return 0
  fi

  # プレフィックスマッチ
  if [[ ${#prefix} -lt $MIN_PREFIX_LEN ]]; then
    die "session-id は最低 ${MIN_PREFIX_LEN} 文字以上指定してください"
  fi

  local matches
  matches=$(echo "$mappings" | jq -r --arg p "$prefix" '[.mappings[] | select(.session_id | startswith($p))] | .[].session_id')
  local count
  count=$(echo "$matches" | grep -c . 2>/dev/null || echo 0)

  case "$count" in
    0) die "マッピングが見つかりません: ${prefix}" ;;
    1) echo "$matches" ;;
    *)
      echo -e "${RED}error:${RESET} 複数のセッションがマッチしました:" >&2
      echo "$matches" | while read -r sid; do
        echo "  ${sid:0:8}..." >&2
      done
      exit 1
      ;;
  esac
}

# ─── Sidebar Helpers ─────────────────────────────────────────────────────────

update_sidebar() {
  local workspace_id="$1" session_status="$2" tasks_json="$3"

  # Status pill
  local color icon
  case "$session_status" in
    active) color="green"; icon="●" ;;
    paused) color="yellow"; icon="⏸" ;;
    *)      color="gray"; icon="○" ;;
  esac
  cmux set-status taskflow "$session_status" --icon "$icon" --color "$color" --workspace "$workspace_id" >/dev/null 2>&1 || true

  # Progress bar
  local total completed progress_value
  total=$(echo "$tasks_json" | jq 'length')
  completed=$(echo "$tasks_json" | jq '[.[] | select(.status == "completed")] | length')

  if [[ "$total" -gt 0 ]]; then
    progress_value=$(echo "scale=2; $completed / $total" | bc)
    cmux set-progress "$progress_value" --label "${completed}/${total} tasks" --workspace "$workspace_id" >/dev/null 2>&1 || true
  else
    cmux clear-progress --workspace "$workspace_id" >/dev/null 2>&1 || true
  fi

  # Task list as log entries
  cmux clear-log --workspace "$workspace_id" >/dev/null 2>&1 || true
  echo "$tasks_json" | jq -r '.[] | "\(.status)\t\(.title)"' | while IFS=$'\t' read -r status title; do
    case "$status" in
      completed)
        cmux log --level success --workspace "$workspace_id" -- "✓ ${title}" >/dev/null 2>&1 || true
        ;;
      *)
        cmux log --level info --workspace "$workspace_id" -- "○ ${title}" >/dev/null 2>&1 || true
        ;;
    esac
  done
}

# ─── Commands ─────────────────────────────────────────────────────────────────

cmd_start() {
  local session_id="${1:-}"
  [[ -z "$session_id" ]] && die "session-id を指定してください\n\nUsage: taskflow-cmux start <session-id>"

  check_deps
  load_config

  # 重複チェック（プレフィックスでも完全IDでもマッピングにあればエラー）
  if has_mapping "$session_id"; then
    die "セッション ${session_id:0:8}... は既にworkspaceに紐づいています"
  fi

  # セッション情報取得
  log_info "セッション情報を取得中..."
  local session_data
  session_data=$(api_get "/api/sessions/${session_id}")

  local session_title session_status
  session_title=$(echo "$session_data" | jq -r '.session.title')
  session_status=$(echo "$session_data" | jq -r '.session.status')

  if [[ "$session_status" == "done" ]]; then
    die "セッションは完了済みです: ${session_title}"
  fi

  # タスク取得
  local tasks_data tasks_json
  tasks_data=$(api_get "/api/sessions/${session_id}/tasks")
  tasks_json=$(echo "$tasks_data" | jq '.tasks // []')

  # Claude Code 初期プロンプトを組み立て
  local claude_prompt
  claude_prompt="セッション「${session_title}」を開始しました。"
  local task_count
  task_count=$(echo "$tasks_json" | jq 'length')
  if [[ "$task_count" -gt 0 ]]; then
    claude_prompt="${claude_prompt}\n\n関連タスク:"
    claude_prompt="${claude_prompt}\n$(echo "$tasks_json" | jq -r '.[] | (if .status == "completed" then "  [完了] " else "  [未着手] " end) + .title')"
  fi

  # プロジェクト作業ディレクトリ解決
  local project_name project_id
  project_name=$(echo "$session_data" | jq -r '.session.project // empty')
  project_id=$(echo "$session_data" | jq -r '.session.project_id // empty')

  local escaped_prompt work_dir
  escaped_prompt=$(echo -e "$claude_prompt" | sed "s/'/'\\\\''/g")
  work_dir=$(resolve_project_dir "$project_name" "$project_id" 2>/dev/null || true)

  local claude_cmd
  if [[ -n "$work_dir" && -d "$work_dir" ]]; then
    claude_cmd="cd '${work_dir}' && claude '${escaped_prompt}'"
    log_info "作業ディレクトリ: ${work_dir}"
  else
    claude_cmd="claude '${escaped_prompt}'"
  fi

  # workspace作成（Claude Code を自動起動）
  log_info "cmux workspace を作成中..."
  local ws_output workspace_id
  ws_output=$(cmux --id-format uuids new-workspace --command "$claude_cmd" 2>/dev/null) || die "cmux workspace の作成に失敗しました"
  # 出力形式: "OK <UUID>"
  workspace_id=$(echo "$ws_output" | awk '{print $2}')

  if [[ -z "$workspace_id" ]]; then
    die "workspace ID を取得できませんでした"
  fi

  # workspace名をセッションタイトルに変更
  cmux rename-workspace --workspace "$workspace_id" "$session_title" >/dev/null 2>&1 || true

  log_debug "workspace_id=${workspace_id}"

  # サイドバー設定
  log_info "サイドバーを設定中..."

  # セッションタイトルをstatus pillで表示
  cmux set-status session "$session_title" --icon "📋" --color "blue" --workspace "$workspace_id" >/dev/null 2>&1 || true

  update_sidebar "$workspace_id" "$session_status" "$tasks_json"

  # マッピング保存
  add_mapping "$session_id" "$workspace_id"

  local task_count
  task_count=$(echo "$tasks_json" | jq 'length')
  log_success "workspace を作成しました: ${session_title} (タスク: ${task_count}件)"
}

cmd_stop() {
  local input_id="${1:-}"
  [[ -z "$input_id" ]] && die "session-id を指定してください\n\nUsage: taskflow-cmux stop <session-id>"

  check_deps
  load_config

  # プレフィックスマッチでsession_id解決
  local session_id
  session_id=$(resolve_session_id_from_mappings "$input_id")

  local workspace_id
  workspace_id=$(find_workspace_id "$session_id")
  [[ -z "$workspace_id" ]] && die "マッピングが見つかりません: ${session_id:0:8}..."

  # API PATCH を先に実行（安全側に倒す）
  log_info "セッションを完了にしています..."
  api_patch "/api/sessions/${session_id}" '{"status":"done"}' >/dev/null

  # workspace閉じる（既に閉じられている可能性があるので失敗OK）
  log_info "workspace を閉じています..."
  cmux close-workspace --workspace "$workspace_id" >/dev/null 2>&1 || log_warn "workspace は既に閉じられています"

  # マッピング削除
  remove_mapping "$session_id"

  log_success "セッション ${session_id:0:8}... を完了しました"
}

cmd_status() {
  init_config_dir
  local mappings
  mappings=$(read_mappings)

  local count
  count=$(echo "$mappings" | jq '.mappings | length')

  if [[ "$count" -eq 0 ]]; then
    log_info "アクティブなマッピングはありません"
    return
  fi

  echo -e "${BOLD}SESSION_ID   WORKSPACE_ID                          CREATED_AT${RESET}"
  echo "─────────────────────────────────────────────────────────────────────────"
  echo "$mappings" | jq -r '.mappings[] | "\(.session_id[:8])...  \(.workspace_id)  \(.created_at)"'
  echo ""
  echo -e "${DIM}合計: ${count} 件${RESET}"
}

cmd_update() {
  local input_id="${1:-}"
  [[ -z "$input_id" ]] && die "session-id を指定してください\n\nUsage: taskflow-cmux update <session-id>"

  check_deps
  load_config

  local session_id
  session_id=$(resolve_session_id_from_mappings "$input_id")

  local workspace_id
  workspace_id=$(find_workspace_id "$session_id")
  [[ -z "$workspace_id" ]] && die "マッピングが見つかりません: ${session_id:0:8}..."

  # 最新情報を取得
  log_info "セッション情報を取得中..."
  local session_data
  session_data=$(api_get "/api/sessions/${session_id}")

  local session_title session_status
  session_title=$(echo "$session_data" | jq -r '.session.title')
  session_status=$(echo "$session_data" | jq -r '.session.status')

  local tasks_data tasks_json
  tasks_data=$(api_get "/api/sessions/${session_id}/tasks")
  tasks_json=$(echo "$tasks_data" | jq '.tasks // []')

  # サイドバー更新
  log_info "サイドバーを更新中..."
  cmux set-status session "$session_title" --icon "📋" --color "blue" --workspace "$workspace_id" >/dev/null 2>&1 || true
  update_sidebar "$workspace_id" "$session_status" "$tasks_json"

  local completed total
  total=$(echo "$tasks_json" | jq 'length')
  completed=$(echo "$tasks_json" | jq '[.[] | select(.status == "completed")] | length')
  log_success "更新完了: ${session_title} (${completed}/${total} tasks)"
}

cmd_sync() {
  check_deps
  load_config

  log_info "同期を開始します..."

  # APIから active と paused セッションを取得（APIは単一status値のみ対応）
  local active_data paused_data
  active_data=$(api_get "/api/sessions?status=active&limit=100")
  paused_data=$(api_get "/api/sessions?status=paused&limit=100")

  # マージ
  local api_sessions
  api_sessions=$(jq -s '.[0].sessions + .[1].sessions' <(echo "$active_data") <(echo "$paused_data"))
  local api_session_ids
  api_session_ids=$(echo "$api_sessions" | jq -r '.[].id')

  # cmux workspaces (--json, --id-format uuids はグローバルフラグ)
  local workspaces workspace_ids
  workspaces=$(cmux --json --id-format uuids list-workspaces 2>/dev/null || echo '{"workspaces":[]}')
  workspace_ids=$(echo "$workspaces" | jq -r '.workspaces[]?.id // empty' 2>/dev/null || echo "")

  # マッピング読み込み
  local mappings
  mappings=$(read_mappings)
  local mapping_count
  mapping_count=$(echo "$mappings" | jq '.mappings | length')

  local synced=0 closed=0 done_count=0 warned=0

  # 各マッピングを処理
  if [[ "$mapping_count" -gt 0 ]]; then
    echo "$mappings" | jq -r '.mappings[] | "\(.session_id)\t\(.workspace_id)"' | while IFS=$'\t' read -r sid wid; do
      # workspace存在チェック
      local ws_exists
      ws_exists=$(echo "$workspace_ids" | grep -c "^${wid}$" || echo 0)

      # API側のセッション状態チェック
      local in_api
      in_api=$(echo "$api_session_ids" | grep -c "^${sid}$" || echo 0)

      if [[ "$ws_exists" -eq 0 ]]; then
        # workspace消失 → セッションをdoneに
        log_warn "セッション ${sid:0:8}...: workspace消失 → done化"
        api_patch "/api/sessions/${sid}" '{"status":"done"}' >/dev/null 2>&1 || true
        remove_mapping "$sid"
      elif [[ "$in_api" -eq 0 ]]; then
        # API側で完了/削除済み → workspace閉鎖
        log_warn "セッション ${sid:0:8}...: API側で完了 → workspace閉鎖"
        cmux close-workspace --workspace "$wid" >/dev/null 2>&1 || true
        remove_mapping "$sid"
      else
        # 両方存在 → サイドバー更新
        local session_data tasks_data session_status tasks_json
        session_data=$(api_get "/api/sessions/${sid}" 2>/dev/null || echo '{}')
        session_status=$(echo "$session_data" | jq -r '.session.status // "active"')
        tasks_data=$(api_get "/api/sessions/${sid}/tasks" 2>/dev/null || echo '{"tasks":[]}')
        tasks_json=$(echo "$tasks_data" | jq '.tasks // []')

        update_sidebar "$wid" "$session_status" "$tasks_json"
        log_info "セッション ${sid:0:8}...: 同期完了"
      fi
    done
  fi

  # マッピングにないがAPI上でactiveなセッションを検出
  if [[ -n "$api_session_ids" ]]; then
    local current_mappings
    current_mappings=$(read_mappings)
    echo "$api_session_ids" | while read -r sid; do
      [[ -z "$sid" ]] && continue
      local mapped
      mapped=$(echo "$current_mappings" | jq -r --arg sid "$sid" '.mappings[] | select(.session_id == $sid) | .session_id // empty')
      if [[ -z "$mapped" ]]; then
        local title
        title=$(echo "$api_sessions" | jq -r --arg sid "$sid" '.[] | select(.id == $sid) | .title // "unknown"')
        log_warn "セッション \"${title}\" (${sid:0:8}...) にworkspaceがありません。taskflow-cmux start ${sid:0:8} で作成してください"
      fi
    done
  fi

  log_success "同期完了"
}

# ─── Main ─────────────────────────────────────────────────────────────────────

main() {
  local command="${1:-}"
  shift >/dev/null 2>&1 || true

  case "$command" in
    start)   cmd_start "$@" ;;
    stop)    cmd_stop "$@" ;;
    status)  cmd_status ;;
    update)  cmd_update "$@" ;;
    sync)    cmd_sync ;;
    help|-h|--help) usage ;;
    "")      usage; exit 1 ;;
    *)       die "不明なコマンド: ${command}\n$(usage)" ;;
  esac
}

main "$@"
